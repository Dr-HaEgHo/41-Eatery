 .navbar-div{
    /* box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.5); */
    font-family: 'Poppins',sans-serif;
    background: #f5f5f5;
 }
 
.logo  {
    color: rgb(231, 157, 19);
}

.logo a {
    font-weight: 700;
    font-size: 20px;
    cursor: pointer;
    color: rgb(231, 157, 19);
    text-decoration: none;
}

.logo a:hover {
    text-decoration: underline;
}
 
 .navbar{
     display: flex;
     align-items: center;
     padding: .5rem 10px;
     justify-content: space-between;
 }

 .nav-links{
     display: flex;
     gap: 2rem;
     list-style: none;
 }
