.footer-body{
    background: rgb(29,29,29);
    padding: 5rem 0 0 0;
    
}

.footer-logo {
    color: rgb(231, 157, 19);
    flex: 2;
    border-right: .5px #555 solid;
}

.footer-logo a{
    font-weight: 700;
    color: rgb(231, 157, 19);
    font-size: 20px;
    cursor: pointer;
    width: fit-content;
    text-decoration: none;
}

.footer-logo a:hover{
    text-decoration: underline;
}


.footer{
    display: flex;
    justify-content: space-between;
}

.links{
    flex: 1;
    border-right: .5px #555 solid;
}

.copy{
    text-align: center;
    margin: 2rem 0 0 0;
    width: 100%;
    color: #555;
    background: #111;
    padding: 1px 0;
}
