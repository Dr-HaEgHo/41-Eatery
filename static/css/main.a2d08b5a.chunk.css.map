.App {
  text-align: center;
}

.App-logo {
  height: 40vmin;
  pointer-events: none;
}

.container{
  width: 90%;
  margin: auto;
  padding: 0 2rem;
  font-family: 'Poppins',
  sans-serif;
}

.shadow-orange {
  box-shadow: 3px 8px 10px rgba(231, 157, 19, 0.3);
}

.btn-light{
  padding: .5rem 1.5rem;
  margin: 0rem 1rem 0 0;
  border-radius: 50px;
  border: 2px rgb(231, 157, 19) solid;
  font-family: 'Poppins', sans-serif;
  background: none;
  min-width: 7rem;
  color: rgb(231, 157, 19);
  font-weight: 500;
  transition: .2s ease all;
}

.btn-light:hover{
  color: rgb(255, 255, 255);
  border: 2px rgb(231, 157, 19) solid;
  background: rgb(231, 157, 19);
}

.btn-dark{
  padding: .5rem 1.5rem;
  border-radius: 50px;
  border: 2px rgb(231, 157, 19) solid;
  font-family: 'Poppins', sans-serif;
  background: rgb(231, 157, 19);
  min-width: 7rem;
  transition: .2s ease all;
  color: #fff;
}

.btn-dark:hover {
  color: rgb(231, 157, 19);
  border: 2px rgb(231, 157, 19) solid;
  background: rgb(255, 255, 255);
}

ul{
  list-style: none;
}

ul li a{
  text-decoration: none;
  color: #555;
  font-size: 15px;
}

ul li a:hover {
  text-decoration: underline;
  /* color: rgb(46, 0, 77); */
  /* color: rgb(58, 36, 36); */
  color: rgb(231, 157, 19);
  font-size: 15px;
}

@media(min-width: 1124px){
  .container{
    max-width: 1124px;
  }
}

@media (prefers-reduced-motion: no-preference) {
  .App-logo {
    animation: App-logo-spin infinite 20s linear;
  }
}

.App-header {
  background-color: #282c34;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: calc(10px + 2vmin);
  color: white;
}

.App-link {
  color: #61dafb;
}

@keyframes App-logo-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
