.prod-body {
    line-height: 0;
    background: #f5f5f5;;
}

.product{
    padding: 5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* margin-bottom: 5rem; */
}

.prod {
    font-family: serif;
    font-size: 20px;
    text-align: center;
    color: rgb(231, 157, 19);
    margin: 0rem 0 3rem 0;

}
p{
    font-size: 14px;
    font-weight: 400;
}

.menu-div{
    /* background: blue; */
    width: 90%;
    padding: 3rem 0; 
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
}

.menus{
    background: #fff;
    width: 30%;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0px 25px 40px rgba(128, 128, 128, 0.3) ;
}

.pic{
    background: rgb(231, 157, 19);
    height: 250px;
    border-radius: 10px;
    object-fit: cover;
    overflow: hidden;
}

.pic img{
    height: 100%;

}

.pizza img{
    width: 100%;
    height: auto;
}
.menu-cont{
    width:90%;
    margin: auto;
    line-height: 17px;
}

.menu-cont p{
    font-size: 14px;
    font-weight: 600;
    color:rgba(59, 59, 59, 0.9)
}

.price{
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.counter{
    display: flex;
    gap: 1rem;
    font-size: 16px;
    background:rgba(161, 161, 161, 0.587);
    width: fit-content;
    padding: 0 10px;
    line-height: 0;
    border-radius: 8px;
    justify-content: center;
    height: fit-content;
}

.counter p{
    font-weight: 600;
    color:rgb(29, 29, 29)
}

.counter p:nth-child(3){
    font-weight: 600;
    color: rgb(123, 48, 35);
}

.num-cart{
    display: flex;
    gap: 8px;
    align-items: center;
}

.num-cart p:nth-child(1){
    color:rgb(29, 29, 29);
    font-weight: 700;
    font-size: 17px;
    font-style: italic;
}

.num-cart p:nth-child(2){
    background: rgb(40, 17, 17);
    font-size: 15px;
    width: fit-content;
    padding: 5px;
    border-radius: 5px;
}

